{
  "name": "@sophonai/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building Sophon Agent Protocol (SAP) connectors and webhook agents.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/serafim-labs/sophon/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/serafim-labs/sophon.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/serafim-labs/sophon/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sophon",
    "sap",
    "agent",
    "webhook",
    "ai",
    "connector"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
